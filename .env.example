# =============================================================================
# Variáveis de ambiente — copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# =============================================================================

# ── Segredos obrigatórios ─────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=SUBSTITUA_POR_UM_VALOR_ALEATORIO_DE_64_CARACTERES

# Senha do superadmin criado automaticamente no primeiro startup
SUPERADMIN_PASSWORD=SUBSTITUA_POR_UMA_SENHA_FORTE
SUPERADMIN_EMAIL=superadmin@suaorganizacao.com

# ── Banco de dados ────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=gestao_organizacional

# ── Redis (rate limiting distribuído) ────────────────────────────────────────
# Deixe vazio para usar rate limiting em memória (não recomendado em produção)
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Domínios permitidos — separados por vírgula
CORS_ORIGINS=http://localhost:3000,https://seudominio.com

# ── Email (para recuperação de senha) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@suaorganizacao.com

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" para filesystem (desenvolvimento) ou "onedrive" para Microsoft OneDrive
STORAGE_BACKEND=local

# Credenciais OneDrive (obrigatório se STORAGE_BACKEND=onedrive)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_DRIVE_ID=
ONEDRIVE_BASE_FOLDER=gestao-organizacional

# ── SSO (opcional) ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID_SSO=common
